}

void consultarClientes(FILE *arq) {
    int numero;
    Cliente c;
    int achou = 0;

    printf("\nDigite o numero da conta para consulta: ");
    scanf("%d", &numero);

    rewind(arq);
    while (fread(&c, sizeof(Conta), 1, arq) == 1) {
        if (c.numeroConta == numero) {
            printf("\n--- Conta Encontrada ---\n");
            printf("Numero: %d\n", c.numeroConta);
            printf("Nome: %s\n", c.nome);
            printf("Saldo: R$ %.2f\n", c.saldo);
            achou = 1;
            break;
        }
    }
    if (!achou) printf("\n[Erro] Conta numero %d nao encontrada.\n", numero);
}

void atualizarSaldo(FILE *arq) {
    int numero;
    Cliente c;
    int achou = 0;

    printf("\nDigite o numero da conta para atualizar saldo: ");
    scanf("%d", &numero);

    rewind(arq);
    while (fread(&c, sizeof(Conta), 1, arq) == 1) {
        if (c.numeroConta == numero) {
            printf("Saldo atual: R$ %.2f\n", c.saldo);
            printf("Digite o novo saldo: ");
            scanf("%f", &c.saldo);

            fseek(arq, -1 * sizeof(Conta), SEEK_CUR);
            fwrite(&c, sizeof(Conta), 1, arq);
            
            printf("[Sucesso] Saldo atualizado!\n");
            achou = 1;
            break;
        }
    }
    if (!achou) printf("\n[Erro] Conta nao encontrada.\n", numero);
}

void removerCliente(FILE *arq) {
    int numero;
    Cliente c;
    int achou = 0;

    printf("\nDigite o numero da conta que deseja encerrar: ");
    scanf("%d", &numero);

    rewind(arq);
    while (fread(&c, sizeof(Conta), 1, arq) == 1) {
        if (c.numeroConta == numero && c.numeroConta > 0) {
            c.numeroConta = 0;
            strcpy(c.nome, "");
            c.saldo = 0.0;

            fseek(arq, -1 * sizeof(Conta), SEEK_CUR);
            fwrite(&c, sizeof(Conta), 1, arq);

            printf("[Sucesso] Conta encerrada/removida com sucesso!\n");
            achou = 1;
            break;
        }
    }
    if (!achou) printf("\n[Erro] Conta nao encontrada.\n", numero);
}

void listarClientes(FILE *arq) {
    Cliente c;
    int cont = 0;

    rewind(arq);
    printf("\n--- LISTAGEM DE CLIENTES ATIVOS ---\n");
    printf("%-10s %-20s %-10s\n", "CONTA", "NOME", "SALDO");
    
    while (fread(&c, sizeof(Conta), 1, arq) == 1) {
        if (c.numeroConta > 0) {
            printf("%-10d %-20s R$ %-10.2f\n", c.numeroConta, c.nome, c.saldo);
            cont++;
        }
    }
    if (cont == 0) printf("Nenhum cliente ativo cadastrado no arquivo.\n");
}
